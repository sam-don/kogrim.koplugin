# macOS. ._* are AppleDouble files, which appear whenever the plugin is copied
# to a FAT-formatted e-reader and back.
.DS_Store
._*

# Claude Code: settings.json is shared config, settings.local.json is personal
# (machine-specific paths, per-user permissions).
.claude/settings.local.json

# Compiled translations. locale/*.po and the .pot are the sources; .mo files are
# generated by msgfmt and are not used on device.
*.mo

# Interrupted downloads leave these behind (see kogrim_http.downloadToFile).
*.tmp

# Release archives built by tools/package.sh. Built artefacts belong on the
# releases page, not in the tree.
dist/
*.zip

# Local tooling secrets. tools/.env carries a real Grimmory URL, username and
# password for the scripts in tools/ -- it must never reach a remote, and this
# repository has two of them (see the note on mirroring in the README).
.env
tools/.env

# Python bytecode from the scripts in tools/.
__pycache__/
*.pyc
